{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "skipLibCheck": true,
    "moduleResolution": "Bundler",
    "types": ["chrome"],
    "outDir": "dist"
  },
  "include": ["*.ts", "*.d.ts"],
  "exclude": ["node_modules", "dist"]
}