{
  "manifest_version": 3,
  "name": "日本版 hulu ピクチャー イン ピクチャー",
  "short_name": "hulu PiP",
  "description": "日本版 hulu の動画を、ピクチャー イン ピクチャー (PiP) で視聴できる拡張機能です。",
  "version": "1.0.0",
  "icons": {
    "16": "icons/16.png",
    "32": "icons/32.png",
    "48": "icons/48.png",
    "64": "icons/64.png",
    "128": "icons/128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/16-gray.png",
      "32": "icons/32-gray.png",
      "48": "icons/48-gray.png",
      "64": "icons/64-gray.png",
      "128": "icons/128-gray.png"
    },
    "default_title": "クリックでピクチャー イン ピクチャーを開始します"
  },
  "permissions": ["scripting", "tabs"],
  "host_permissions": ["https://*.hulu.jp/*"],
  "web_accessible_resources": [
    {
      "resources": [ "img/*.png" ],
      "matches": [ "https://*.hulu.jp/*" ]
    }
  ],
  "background": {
    "service_worker": "dist/background.js"
  }
}
